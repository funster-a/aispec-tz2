{
  "name": "order-dashboard-monorepo",
  "version": "1.0.0",
  "description": "Order dashboard monorepo with scripts and Telegram bot.",
  "private": true,
  "workspaces": [
    "dashboard",
    "bot",
    "scripts"
  ],
  "scripts": {
    "dashboard:dev": "npm run dev -w dashboard",
    "dashboard:build": "npm run build -w dashboard",
    "bot:start": "node bot/telegram-bot.js",
    "scripts:upload": "node scripts/upload-to-retailcrm.js",
    "scripts:sync": "node scripts/sync-to-supabase.js"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "@supabase/supabase-js": "^2.38.0",
    "node-telegram-bot-api": "^0.64.0"
  }
}

